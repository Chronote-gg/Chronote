{
  "name": "meeting-minutes-discord-bot",
  "version": "1.0.0",
  "description": "Record and transcribe conversations in Discord",
  "main": "src/index.ts",
  "scripts": {
    "start": "node scripts/dev.js start",
    "start:inner": "nodemon --exec ts-node src/index.ts",
    "start:mock": "node scripts/dev.js start:mock",
    "start:mock:inner": "nodemon --exec \"ts-node src/index.ts --mock\"",
    "start:mock:once": "ts-node src/index.ts --mock",
    "build": "tsc",
    "build:web": "vite build",
    "build:all": "yarn build && yarn build:web",
    "serve": "node dist/index.js",
    "serve:bot": "node dist/apps/bot/main.js",
    "serve:api": "node dist/apps/api/main.js",
    "terraform:init": "terraform -chdir=_infra init",
    "terraform:plan": "terraform -chdir=_infra plan",
    "terraform:apply": "terraform -chdir=_infra apply",
    "terraform:plan:prod": "terraform -chdir=_infra plan -var-file=terraform.tfvars",
    "terraform:apply:prod": "terraform -chdir=_infra apply -var-file=terraform.tfvars",
    "terraform:plan:staging": "terraform -chdir=_infra plan -var-file=terraform.staging.tfvars",
    "terraform:apply:staging": "terraform -chdir=_infra apply -var-file=terraform.staging.tfvars",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "node scripts/run-visual-tests.js",
    "test:visual:update": "node scripts/run-visual-tests.js --update-snapshots",
    "lint": "eslint --fix src test",
    "lint:check": "eslint src test",
    "prettier": "prettier . --write",
    "prettier:check": "prettier . --check",
    "frontend:dev": "vite",
    "frontend:preview": "vite preview",
    "docs:dev": "docusaurus start apps/docs-site --host 0.0.0.0 --port 3002",
    "docs:build": "docusaurus build apps/docs-site --out-dir ../../build/docs-site",
    "docs:serve": "docusaurus serve apps/docs-site --dir ../../build/docs-site --host 0.0.0.0 --port 3003",
    "docs:check": "yarn docs:build",
    "storybook": "storybook dev -p 6006 -c .storybook --no-open",
    "storybook:open": "storybook dev -p 6006 -c .storybook",
    "build-storybook": "storybook build -c .storybook",
    "test-storybook": "test-storybook --url http://localhost:6006 -c .storybook",
    "prepare": "husky",
    "init": "npm install --legacy-peer-deps && npx husky init && npm run init:husky-hooks",
    "init:husky-hooks": "echo 'npx lint-staged' > .husky/pre-commit",
    "docker:setup": "node scripts/setup-dynamodb-dir.js",
    "docker:build": "docker build -t meeting-notes-bot-ci .",
    "docker:up": "npm run docker:setup && docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "node scripts/clean-dynamodb.js",
    "db:init": "node scripts/init-dynamodb.js",
    "dev": "node scripts/dev.js dev",
    "dev:inner": "npm run docker:up && npm run db:init && npm run start:inner",
    "dev:mock": "node scripts/dev.js dev:mock",
    "dev:mock:inner": "npm run docker:up && npm run db:init && npm run start:mock:inner",
    "dev:clean": "npm run docker:down && npm run docker:clean && npm run dev",
    "observability:up": "docker compose -f docker-compose.observability.yml up -d",
    "observability:down": "docker compose -f docker-compose.observability.yml down",
    "docker:minio-init": "docker-compose run --rm minio-init",
    "checkov": "uvx --from checkov checkov -d _infra --quiet --compact",
    "check": "run-s lint prettier check:parallel",
    "check:parallel": "run-p test build:all docs:check code:stats prompts:check llm-connections:check markdownlint:check docker:build",
    "check:ci": "run-p lint:check prettier:check markdownlint:check test build:all docs:check test:e2e checkov code:stats prompts:check llm-connections:check docker:build",
    "stripe:listen": "stripe listen --forward-to http://localhost:3001/api/billing/webhook",
    "stripe:trigger": "stripe trigger",
    "stripe:trigger:checkout": "stripe trigger checkout.session.completed",
    "stripe:trigger:invoice-paid": "stripe trigger invoice.payment_succeeded",
    "stripe:trigger:invoice-failed": "stripe trigger invoice.payment_failed",
    "stripe:trigger:subscription-updated": "stripe trigger customer.subscription.updated",
    "stripe:trigger:subscription-deleted": "stripe trigger customer.subscription.deleted",
    "eval:meeting-summary": "ts-node src/evals/meetingSummaryEval.ts",
    "eval:transcription": "ts-node src/evals/transcriptionEval.ts",
    "prompts:push": "ts-node scripts/prompts/push.ts",
    "prompts:pull": "ts-node scripts/prompts/pull.ts",
    "prompts:check": "ts-node scripts/prompts/check.ts",
    "llm-connections:push": "ts-node scripts/llm-connections/push.ts",
    "llm-connections:pull": "ts-node scripts/llm-connections/pull.ts",
    "llm-connections:check": "ts-node scripts/llm-connections/check.ts",
    "code:stats": "scc --ci && scc --ci --by-file --sort lines && python -m lizard -W whitelizard.txt -l ts -l tsx -l js -l jsx src test",
    "markdownlint:check": "markdownlint-cli2 \"**/*.md\"",
    "markdownlint:fix": "markdownlint-cli2 --fix \"**/*.md\""
  },
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "author": "BASIC-BIT",
  "license": "AGPL-3.0-or-later",
